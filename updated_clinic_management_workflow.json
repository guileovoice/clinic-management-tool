        "jsCode": "const toolCallId = $('Extract Request Params1').item.json.toolCallId || \"test_run_id\";\nlet rows = [];\nconst currentItem = $json;\nif (Array.isArray(currentItem)) {\n  rows = currentItem;\n} else if (currentItem && typeof currentItem === 'object' && Object.keys(currentItem).length > 0) {\n  rows = [currentItem];\n}\nconst isBooked = rows.some(r => r && r.id !== undefined && r.id !== null && r.id !== '');\nreturn [{\n  json: {\n    results: [{\n      toolCallId,\n      result: isBooked ? \"Slot is already booked.\" : \"Slot is available.\"\n    }]\n  }\n}];"
