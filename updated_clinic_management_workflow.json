    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst msg  = body.message || {};\n\nif (msg.type !== 'end-of-call-report') return [];\n\nconst call = msg.call || {};\n\nconst soKeys = Object.keys(msg.artifact?.structuredOutputs || {});\nlet sd = {};\nif (soKeys.length > 0) {\n  sd = msg.artifact.structuredOutputs[soKeys[0]]?.result || {};\n  if (sd.result) sd = sd.result;\n}\n\nconst callerPhone = call.customer?.number || '';\nconst whatsappRaw = sd.patientPhone || callerPhone || '';\n\nconst toE164 = (raw) => {\n  if (!raw) return '';\n  const d = String(raw).replace(/\\D/g, '');\n  if (d.length === 10) return '+1' + d;\n  if (d.length === 11 && d.startsWith('1')) return '+' + d;\n  return d ? ('+' + d) : '';\n};\n\nconst callerE164   = toE164(callerPhone);\n\nconst patientName = sd.patientName || 'Guest';\nconst appointmentDate = sd.appointmentDate || new Date().toISOString().slice(0, 10);\nconst appointmentTime = sd.appointmentTime || '09:00';\nconst appointmentType = (sd.appointmentType || 'CHECKUP').toUpperCase();\nconst notes = sd.notes || '';\n\nreturn [{\n  json: {\n    tenant_id:\n  body.tenant_id ||\n  \"395b50b9-9504-4bda-bd38-7ce5b53e7aa0\",\n    patientName,\n    patientPhone: callerE164,\n    appointmentDate,\n    appointmentTime,\n    appointmentType,\n    notes,\n    channel: 'VOICE',\n    status: 'PENDING'\n  }\n}];"
      },
