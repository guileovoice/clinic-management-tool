      "parameters": {
        "jsCode": "const raw = $input.first()?.json || {};\nlet incoming = raw;\nif (raw.body && typeof raw.body === 'object') {\n  incoming = raw.body;\n}\nconst toolCalls = incoming.message?.toolCalls || incoming.message?.toolCallList || incoming.toolCalls || incoming.toolCallList || null;\nconst singleCall = (Array.isArray(toolCalls) && toolCalls[0]) || toolCalls || null;\nlet args = singleCall?.function?.arguments ?? singleCall?.arguments ?? incoming ?? {};\nif (typeof args === \"string\") {\n  try { args = JSON.parse(args); } catch (e) { args = {}; }\n}\nconst date = args.date || incoming.date || null;\nlet time = args.time || incoming.time || null;\nconst tenantId = args.tenant_id || args.tenantId || incoming.tenant_id || \"395b50b9-9504-4bda-bd38-7ce5b53e7aa0\";\nif (time && /^\\d{2}:\\d{2}$/.test(time)) {\n  time = `${time}:00`;\n}\nconst toolCallId = singleCall?.id || singleCall?.toolCallId || incoming.toolCallId || \"test_run_id\";\nconst supabaseUrl = \"https://iifkgbblhyyomyizclam.supabase.co/rest/v1/appointments?select=id&limit=1&tenant_id=eq.\" + encodeURIComponent(tenantId) + \"&date=eq.\" + encodeURIComponent(date) + \"&time=eq.\" + encodeURIComponent(time);\nreturn [{\n  json: {\n    toolCallId,\n    date,\n    time,\n    tenant_id: tenantId,\n    supabaseUrl\n  }\n}];"
